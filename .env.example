# Django
SECRET_KEY=change-me-in-production-use-strong-random-key
DEBUG=true

# Database
# Standard postgres:// format
DATABASE_URL=postgresql://someuser:somepass@10.0.10.50:5432/astrosite
ASTRO_API_URL=http://localhost:8086
# Alternative individual settings (used if DATABASE_URL not set)
POSTGRES_DB=astrology
POSTGRES_USER=someuser
POSTGRES_PASSWORD=somepass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# Google OAuth (see docs/google-oauth-setup.md)
# Option 1: Point to a JSON credentials file
# GOOGLE_OAUTH_CLIENT_SECRET_FILE=credentials/google_client_secret.json
# Option 2: Set directly (less secure for production)
# GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
